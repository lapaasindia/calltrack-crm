{
  "name": "calltrack-crm",
  "version": "1.0.0",
  "description": "CallTrack CRM — calling team CRM with full tracking (LAN-deployed)",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "test": "node --test server/test/",
    "build": "npm --prefix client run build",
    "setup": "npm install && npm --prefix client install && npm --prefix client run build && node server/seed.js",
    "install-autostart": "node scripts/install-autostart.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "qrcode-terminal": "^0.12.0"
  }
}
