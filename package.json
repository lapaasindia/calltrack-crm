{
  "name": "calltrack-crm",
  "version": "1.1.1",
  "description": "CallTrack CRM — calling team CRM with full tracking (local-only)",
  "private": true,
  "type": "module",
  "main": "desktop/main.js",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "start": "node server/index.js",
    "seed": "node server/seed.js",
    "test": "node --test server/test/*.test.js",
    "build": "npm --prefix client run build",
    "setup": "npm install && npm --prefix client install && npm --prefix client run build && node server/seed.js",
    "install-autostart": "node scripts/install-autostart.js",
    "app": "electron .",
    "app:rebuild": "electron-rebuild -f -w better-sqlite3 && codesign --force --sign - node_modules/better-sqlite3/build/Release/better_sqlite3.node",
    "icons": "electron desktop/make-icon.js",
    "dist:mac": "npm run build && electron-builder --mac && npm rebuild better-sqlite3",
    "dist:win": "npm run build && node scripts/fetch-win-sqlite.js && electron-builder --win -c.npmRebuild=false && npm rebuild better-sqlite3",
    "dist": "npm run build && electron-builder --mac && node scripts/fetch-win-sqlite.js && electron-builder --win -c.npmRebuild=false && npm rebuild better-sqlite3"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/preferences": "^6.0.4",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "multer": "^2.1.1",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "electron": "^36.9.5",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.calltrack.crm",
    "productName": "CallTrack CRM",
    "afterPack": "scripts/afterpack-sign.cjs",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "desktop/**/*",
      "!desktop/make-icon.js",
      "server/**/*",
      "!server/test/**",
      "client/dist/**/*",
      "scripts/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "mac": {
      "category": "public.app-category.business",
      "artifactName": "CallTrack-CRM-${version}-mac-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "artifactName": "CallTrack-CRM-Setup-${version}-win-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
